  "comments": {
    "required_fields": "Rule fields that should always be set: id, name, transaction_category, priority, transaction_type.",
    "optional_fields": "Optional rule filters: services, providers, merchants, locations, include_keywords, exclude_keywords. Empty list means 'do not filter by this field'.",
    "transaction_type": "Required filter by money direction: 'credit' or 'debit'.",
    "services": "Optional filter on parsed generic service type (e.g. Karteneinkauf, Twint, Lastschrift).",
    "providers": "Optional filter on payment provider (e.g. Apple Pay). Provider must NOT be encoded in services.",
    "merchants": "Optional merchant filter (case-insensitive). OR logic (at least one must match).",
    "locations": "Optional location filter (case-insensitive). AND logic (all listed locations must match).",
    "include_keywords": "Optional keywords that MUST be present. AND logic.",
    "exclude_keywords": "Optional keywords that must NOT be present. NONE may be present.",
    "matching": "A rule matches only if all active (non-empty) filters are satisfied. Highest priority wins.",
    "fallback": "No fallback category. If no rule matches, transaction stays uncategorized.",
    "subcategory": "Optional subcategory for fine-grained classification (e.g. 'Gastronomie' within 'Freizeit'). Empty string if not applicable.",
    "category": "Optional high-level category mapping. Empty string if not applicable.",
    "transaction_category": "Required classification bucket: one of income, expense, refund, transfer.",
